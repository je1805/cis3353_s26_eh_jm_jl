# =========================
# CIS 3353 - Coffee Shop Security Lab Environment Variables
# =========================

# --- Network Configuration ---
NETWORK_SUBNET=your_value_here
# Docker assigns the gateway IP to the bridge interface on the host (WSL VM).
# We park it at .254 so the firewall container can claim the well-known .1
# address. The firewall still sits on coffeeshop-net and iptables-filters its
# own traffic; it just isn't literally the L3 gateway Docker uses.
NETWORK_GATEWAY=your_value_here

# --- Container IP Addresses ---
FIREWALL_IP=your_value_here
WAZUH_MANAGER_IP=your_value_here
WAZUH_DASHBOARD_IP=your_value_here
WAZUH_INDEXER_IP=your_value_here
JOKOPI_APP_IP=your_value_here
KALI_IP=your_value_here

# --- Wazuh Configuration ---
WAZUH_MANAGER_HOSTNAME=your_value_here
WAZUH_INDEXER_HOSTNAME=your_value_here
WAZUH_DASHBOARD_HOSTNAME=your_value_here
WAZUH_API_USER=your_value_here
WAZUH_API_PASSWORD=your_value_here
INDEXER_USERNAME=your_value_here
INDEXER_PASSWORD=your_value_here

# --- Jokopi App Configuration ---
JOKOPI_PORT=your_value_here
JOKOPI_ADMIN_USER=your_value_here
JOKOPI_ADMIN_PASS=your_value_here

# --- Firewall Configuration ---
FIREWALL_ADMIN_USER=your_value_here
FIREWALL_ADMIN_PASS=your_value_here
FIREWALL_WEB_PORT=your_value_here

# --- Wazuh Agent Registration ---
WAZUH_REGISTRATION_PASSWORD=your_value_here
