<!--
  =============================================================================
  Custom Wazuh Detection Rules - CIS 3353 Security Lab
  =============================================================================
  These rules detect attacks against the Jokopi Coffee Shop application:
    - SQL Injection attempts (web logs)
    - Cross-Site Scripting (XSS) attempts
    - Brute-force login attacks
    - Port scanning activity
    - DoS/DDoS indicators
    - Directory traversal attempts
    - Data exfiltration indicators
    - File integrity changes
  =============================================================================
  Rule ID ranges:
    100100-100199: Web application attack rules
    100200-100299: Network attack rules
    100300-100399: Firewall integration rules
    100400-100499: Custom correlation rules
  =============================================================================
-->

<group name="coffeeshop,web-attacks,">

  <!-- =====================================================================
       SQL INJECTION DETECTION
       ===================================================================== -->

  <!-- Detect SQL injection patterns in Nginx access logs -->
  <rule id="100100" level="12">
    <if_group>web|accesslog|nginx</if_group>
    <regex>select.*from|union.*select|insert.*into|delete.*from|drop.*table|update.*set</regex>
    <description>SQL Injection attempt detected in web request to Jokopi app</description>
    <mitre>
      <id>T1190</id>
    </mitre>
    <group>attack,sqli,web-attack,coffeeshop,</group>
  </rule>

  <!-- Detect SQL injection via encoded characters -->
  <rule id="100101" level="12">
    <if_group>web|accesslog|nginx</if_group>
    <regex>%27|%22|%3D|%3B|%2D%2D|%23|%2A|1%3D1|1=1</regex>
    <description>Encoded SQL Injection attempt detected (URL-encoded special characters)</description>
    <mitre>
      <id>T1190</id>
    </mitre>
    <group>attack,sqli,web-attack,coffeeshop,</group>
  </rule>

  <!-- Detect sqlmap user agent -->
  <rule id="100102" level="14">
    <if_group>web|accesslog|nginx</if_group>
    <regex>sqlmap|havij|pangolin|sql.*ninja</regex>
    <description>Automated SQL Injection tool (sqlmap) detected targeting Jokopi</description>
    <mitre>
      <id>T1190</id>
    </mitre>
    <group>attack,sqli,web-attack,coffeeshop,automated-tool,</group>
  </rule>

  <!-- =====================================================================
       CROSS-SITE SCRIPTING (XSS) DETECTION
       ===================================================================== -->

  <rule id="100110" level="10">
    <if_group>web|accesslog|nginx</if_group>
    <regex>\x3cscript|%3Cscript|javascript:|onerror=|onload=|onclick=|onfocus=</regex>
    <description>XSS attempt detected in web request to Jokopi app</description>
    <mitre>
      <id>T1189</id>
    </mitre>
    <group>attack,xss,web-attack,coffeeshop,</group>
  </rule>

  <rule id="100111" level="10">
    <if_group>web|accesslog|nginx</if_group>
    <regex>alert\(|document\.cookie|document\.location|eval\(|String\.fromCharCode</regex>
    <description>XSS payload execution attempt detected</description>
    <mitre>
      <id>T1189</id>
    </mitre>
    <group>attack,xss,web-attack,coffeeshop,</group>
  </rule>

  <!-- =====================================================================
       BRUTE-FORCE LOGIN DETECTION
       ===================================================================== -->

  <!-- Single failed login -->
  <rule id="100120" level="5">
    <decoded_as>json</decoded_as>
    <regex>LOGIN_FAILED|Invalid credentials</regex>
    <description>Failed login attempt on Jokopi Coffee Shop</description>
    <group>authentication_failed,coffeeshop,</group>
  </rule>

  <!-- Pattern match on auth log -->
  <rule id="100121" level="5">
    <match>LOGIN_FAILED</match>
    <description>Failed login attempt recorded in Jokopi auth log</description>
    <group>authentication_failed,coffeeshop,</group>
  </rule>

  <!-- Brute-force: 5 failed logins in 60 seconds from same source -->
  <rule id="100122" level="12" frequency="5" timeframe="60">
    <if_matched_sid>100121</if_matched_sid>
    <same_source_ip/>
    <description>BRUTE-FORCE: 5+ failed login attempts in 60 seconds on Jokopi app</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>attack,brute-force,authentication_failures,coffeeshop,</group>
  </rule>

  <!-- Severe brute-force: 20 failed logins in 120 seconds -->
  <rule id="100123" level="15" frequency="20" timeframe="120">
    <if_matched_sid>100121</if_matched_sid>
    <same_source_ip/>
    <description>SEVERE BRUTE-FORCE: 20+ failed logins in 120s - Automated attack likely (hydra/medusa)</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>attack,brute-force,automated-tool,coffeeshop,</group>
  </rule>

  <!-- =====================================================================
       DIRECTORY TRAVERSAL DETECTION
       ===================================================================== -->

  <rule id="100130" level="10">
    <if_group>web|accesslog|nginx</if_group>
    <regex>\.\.\/|\.\.\\|%2e%2e|%252e%252e|/etc/passwd|/etc/shadow</regex>
    <description>Directory traversal attempt detected against Jokopi app</description>
    <mitre>
      <id>T1083</id>
    </mitre>
    <group>attack,directory-traversal,web-attack,coffeeshop,</group>
  </rule>

  <!-- Detect nikto scanner -->
  <rule id="100131" level="12">
    <if_group>web|accesslog|nginx</if_group>
    <regex>Nikto|nikto|DirBuster|dirbuster|gobuster|Gobuster</regex>
    <description>Web vulnerability scanner detected targeting Jokopi (nikto/dirbuster/gobuster)</description>
    <mitre>
      <id>T1595</id>
    </mitre>
    <group>attack,web-scanner,recon,coffeeshop,automated-tool,</group>
  </rule>

  <!-- =====================================================================
       DATA EXFILTRATION INDICATORS
       ===================================================================== -->

  <!-- Detect access to the exposed database file -->
  <rule id="100140" level="14">
    <if_group>web|accesslog|nginx</if_group>
    <regex>/data/coffeeshop\.db|/data/.*\.db|/data/.*\.sqlite</regex>
    <description>CRITICAL: Database file access attempt - possible data exfiltration from Jokopi</description>
    <mitre>
      <id>T1005</id>
    </mitre>
    <group>attack,data-exfiltration,coffeeshop,</group>
  </rule>

  <!-- Detect access to phpinfo -->
  <rule id="100141" level="8">
    <if_group>web|accesslog|nginx</if_group>
    <regex>/api/info\.php|phpinfo</regex>
    <description>Server information disclosure page accessed on Jokopi</description>
    <mitre>
      <id>T1592</id>
    </mitre>
    <group>attack,information-disclosure,recon,coffeeshop,</group>
  </rule>

</group>

<!-- =========================================================================
     NETWORK ATTACK RULES
     ========================================================================= -->
<group name="coffeeshop,network-attacks,">

  <!-- Port scan detection from firewall logs -->
  <rule id="100200" level="10">
    <match>FW-PORTSCAN</match>
    <description>Port scan detected by firewall (RST packets threshold exceeded)</description>
    <mitre>
      <id>T1046</id>
    </mitre>
    <group>attack,port-scan,recon,coffeeshop,</group>
  </rule>

  <!-- SYN flood detection from firewall logs -->
  <rule id="100210" level="14">
    <match>FW-SYNFLOOD</match>
    <description>SYN Flood attack detected by firewall rate limiter</description>
    <mitre>
      <id>T1498</id>
    </mitre>
    <group>attack,dos,syn-flood,coffeeshop,</group>
  </rule>

  <!-- HTTP flood detection -->
  <rule id="100211" level="12">
    <match>FW-HTTPFLOOD</match>
    <description>HTTP Flood attack detected - excessive requests from single source</description>
    <mitre>
      <id>T1498</id>
    </mitre>
    <group>attack,dos,http-flood,coffeeshop,</group>
  </rule>

  <!-- Connection limit exceeded -->
  <rule id="100212" level="10">
    <match>FW-CONNLIMIT</match>
    <description>Connection limit exceeded - possible DoS or scanning activity</description>
    <mitre>
      <id>T1498</id>
    </mitre>
    <group>attack,dos,coffeeshop,</group>
  </rule>

  <!-- General firewall drop events -->
  <rule id="100220" level="4">
    <match>FW-DROP</match>
    <description>Firewall dropped a packet (policy violation)</description>
    <group>firewall,drop,coffeeshop,</group>
  </rule>

  <!-- Blocked attacker events -->
  <rule id="100230" level="8">
    <match>FW-BLOCKED-ATTACKER</match>
    <description>Traffic from blocked attacker IP dropped by firewall (active response)</description>
    <group>firewall,blocked,active-response,coffeeshop,</group>
  </rule>

</group>

<!-- =========================================================================
     ACTIVE RESPONSE TRIGGER RULES
     ========================================================================= -->
<group name="coffeeshop,active-response-triggers,">

  <!-- Auto-block on severe brute-force -->
  <rule id="100300" level="15">
    <if_sid>100123</if_sid>
    <description>ACTIVE RESPONSE TRIGGER: Severe brute-force detected - blocking attacker IP on firewall</description>
    <group>active-response,auto-block,coffeeshop,</group>
  </rule>

  <!-- Auto-block on automated SQLi tool -->
  <rule id="100301" level="15">
    <if_sid>100102</if_sid>
    <description>ACTIVE RESPONSE TRIGGER: Automated SQLi tool detected - blocking attacker IP on firewall</description>
    <group>active-response,auto-block,coffeeshop,</group>
  </rule>

  <!-- Auto-block on SYN flood -->
  <rule id="100302" level="15">
    <if_sid>100210</if_sid>
    <description>ACTIVE RESPONSE TRIGGER: SYN Flood detected - blocking attacker IP on firewall</description>
    <group>active-response,auto-block,coffeeshop,</group>
  </rule>

  <!-- Auto-block on database exfiltration -->
  <rule id="100303" level="15">
    <if_sid>100140</if_sid>
    <description>ACTIVE RESPONSE TRIGGER: Database access attempt - blocking attacker IP on firewall</description>
    <group>active-response,auto-block,coffeeshop,</group>
  </rule>

</group>
