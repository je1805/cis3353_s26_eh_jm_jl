<!--
  =============================================================================
  Custom Wazuh Decoders - CIS 3353 Security Lab
  =============================================================================
  Decoders for parsing custom log formats from:
    - Jokopi authentication logs
    - Firewall iptables logs
    - Active response logs
  =============================================================================
-->

<!-- Jokopi Auth Log Decoder -->
<decoder name="jokopi-auth">
  <prematch>LOGIN_</prematch>
  <regex>(\d+-\d+-\d+ \d+:\d+:\d+) (LOGIN_\S+) user=(\S+) src=(\S+)</regex>
  <order>timestamp,action,user,srcip</order>
</decoder>

<!-- Jokopi Auth - Failed Login -->
<decoder name="jokopi-auth-failed">
  <parent>jokopi-auth</parent>
  <regex>LOGIN_FAILED</regex>
  <order>action</order>
</decoder>

<!-- Jokopi Auth - Successful Login -->
<decoder name="jokopi-auth-success">
  <parent>jokopi-auth</parent>
  <regex>LOGIN_SUCCESS</regex>
  <order>action</order>
</decoder>

<!-- Firewall iptables Log Decoder -->
<!--
  NOTE: In OSSEC/Wazuh's OS_Regex engine, `[` and `]` are LITERAL characters
  and must NOT be backslash-escaped. `\[` produces "(1452): Syntax error on
  regex" because OS_Regex does not recognize `\[` as an escape sequence
  (unlike PCRE / Python). If you want the familiar escape syntax, use the
  <pcre2> tag instead of <regex>.
-->
<decoder name="coffeeshop-firewall">
  <prematch>[FW-</prematch>
  <regex>[(FW-\S+)] IN=(\S*) OUT=(\S*) SRC=(\S+) DST=(\S+) .*PROTO=(\S+)</regex>
  <order>action,in_iface,out_iface,srcip,dstip,protocol</order>
</decoder>

<!-- Firewall with port information -->
<decoder name="coffeeshop-firewall-ports">
  <parent>coffeeshop-firewall</parent>
  <regex>SPT=(\d+) DPT=(\d+)</regex>
  <order>srcport,dstport</order>
</decoder>

<!-- Active Response Log Decoder -->
<decoder name="coffeeshop-active-response">
  <prematch>BLOCKED:|UNBLOCKED:|FLUSHED:</prematch>
  <regex>(\S+): IP (\S+)</regex>
  <order>action,srcip</order>
</decoder>

<!-- Search Request Decoder -->
<decoder name="jokopi-search">
  <prematch>SEARCH REQUEST:</prematch>
  <regex>SEARCH REQUEST: q=(.*) from=(\S+)</regex>
  <order>query,srcip</order>
</decoder>

<!-- Comment Post Decoder -->
<decoder name="jokopi-comment">
  <prematch>COMMENT POST:</prematch>
  <regex>COMMENT POST: name=(.*) from=(\S+)</regex>
  <order>user,srcip</order>
</decoder>
