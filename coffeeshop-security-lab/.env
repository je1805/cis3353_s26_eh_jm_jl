# =============================================================================
# CIS 3353 - Coffee Shop Security Lab Environment Variables
# =============================================================================

# --- Network Configuration ---
NETWORK_SUBNET=10.10.0.0/24
# Docker assigns the gateway IP to the bridge interface on the host (WSL VM).
# We park it at .254 so the firewall container can claim the well-known .1
# address. The firewall still sits on coffeeshop-net and iptables-filters its
# own traffic; it just isn't literally the L3 gateway Docker uses.
NETWORK_GATEWAY=10.10.0.254

# --- Container IP Addresses ---
FIREWALL_IP=10.10.0.1
WAZUH_MANAGER_IP=10.10.0.10
WAZUH_DASHBOARD_IP=10.10.0.11
WAZUH_INDEXER_IP=10.10.0.12
JOKOPI_APP_IP=10.10.0.20
KALI_IP=10.10.0.100

# --- Wazuh Configuration ---
WAZUH_MANAGER_HOSTNAME=wazuh-manager
WAZUH_INDEXER_HOSTNAME=wazuh-indexer
WAZUH_DASHBOARD_HOSTNAME=wazuh-dashboard
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=MyS3cr3tP4ssw0rd!
INDEXER_USERNAME=admin
INDEXER_PASSWORD=SecretPassword!123

# --- Jokopi App Configuration ---
JOKOPI_PORT=80
JOKOPI_ADMIN_USER=admin
JOKOPI_ADMIN_PASS=coffee123

# --- Firewall Configuration ---
FIREWALL_ADMIN_USER=admin
FIREWALL_ADMIN_PASS=pfsense!2026
FIREWALL_WEB_PORT=8443

# --- Wazuh Agent Registration ---
WAZUH_REGISTRATION_PASSWORD=AgentRegistration!2026
