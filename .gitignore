# .gitignore file for coffee shop project
# ==========================================
# SECURITY & SECRETS
# ==========================================
.env
.env.swp
*.key
*.pem
secrets/
# Keep the example file so others know what variables to use
!.env.example

# ==========================================
# AI ASSISTANTS (Claude, Cursor, etc.)
# ==========================================
# Prevents AI tools from indexing large/sensitive local files
.claude/
.cursor/
.cline/
claude_scratch/
*-mcp.json
.cursorignore
.claudeignore

# ==========================================
# DOCKER
# ==========================================
.dockerignore
# Ignore local data volumes if you mount them
data/db/
pgdata/

# ==========================================
# OPERATING SYSTEMS
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
__MACOSX/

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.fuse_hidden
.directory
.Trash-*
.nfs*

# ==========================================
# EDITORS & TOOLS
# ==========================================
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Local Vim/Emacs swap files
[._]s[a-v][a-z]
[._]sw[a-p]
*~
.netrwhist

# ==========================================
# PROJECT SPECIFIC (From your image)
# ==========================================
# If that nested folder is a redundant unzip
# coffeeshop-security-lab/